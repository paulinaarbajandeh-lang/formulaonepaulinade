{
	"name": "pl_ingestion_formulaone",
	"properties": {
		"activities": [
			{
				"name": "formulaone_copy_data",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "JsonSource",
						"storeSettings": {
							"type": "HttpReadSettings",
							"requestMethod": "GET"
						},
						"formatSettings": {
							"type": "JsonReadSettings"
						}
					},
					"sink": {
						"type": "JsonSink",
						"storeSettings": {
							"type": "AzureBlobStorageWriteSettings",
							"copyBehavior": {
								"value": "@concat('iss_location_', formatDateTime(utcNow(), 'yyyyMMdd_HHmmss'), '.json')",
								"type": "Expression"
							}
						},
						"formatSettings": {
							"type": "JsonWriteSettings"
						}
					},
					"enableStaging": false
				},
				"inputs": [
					{
						"referenceName": "ds_openf1",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "ds_storage_sink",
						"type": "DatasetReference"
					}
				]
			}
		],
		"annotations": []
	}
}